# Copy to .env.local and fill in your Supabase values for local testing.
# Vercel uses the same variables (set them in the Vercel dashboard).
# With NONE of these set, the app runs in local JSON-file + disk mode.

# --- Supabase (data + screenshot storage) ---
# Postgres connection string: Supabase > Project Settings > Database >
# "Connection string" > URI (use the Transaction pooler for serverless).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Supabase API: Project Settings > API
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role secret key>
SUPABASE_BUCKET=screenshots

# --- Admin login ---
ADMIN_ID=admin
# Either set a plaintext password (simplest) ...
ADMIN_PASSWORD=change-me-to-a-strong-password
# ... or, MORE SECURE, store only a scrypt hash and omit ADMIN_PASSWORD.
# Generate with:  npm run hash-password -- 'YourStr0ng!Passphrase'
# ADMIN_PASSWORD_HASH=scrypt$<salt>$<hash>
# Read-only viewer account (optional): VIEWER_PASSWORD or VIEWER_PASSWORD_HASH
# Signs/validates session tokens — set a long random value in production:
AUTH_SECRET=generate-with-openssl-rand-hex-32

# --- Pricing (optional) ---
EARLY_BIRD_CUTOFF=2026-08-15
