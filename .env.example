# Copy to .env.local for local Postgres/Blob testing, or set these in Vercel.
# With NONE of these set, the app runs in local JSON-file + disk mode.

# Admin login
ADMIN_ID=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
AUTH_SECRET=generate-with-openssl-rand-hex-32

# Pricing (optional override)
EARLY_BIRD_CUTOFF=2026-08-15

# Storage (auto-set by Vercel when you connect Postgres + Blob)
# DATABASE_URL or POSTGRES_URL = postgres://...
# BLOB_READ_WRITE_TOKEN = vercel_blob_rw_...
